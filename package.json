{
  "name": "tauri-app",
  "private": true,
  "version": "9000.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:mac-arm": "tauri build --target aarch64-apple-darwin && node scripts/rename-release.js mac-arm",
    "build:mac-intel": "tauri build --target x86_64-apple-darwin && node scripts/rename-release.js mac-intel",
    "build:win": "tauri build && node scripts/rename-release.js win",
    "build:all": "npm run build:mac-arm && npm run build:mac-intel"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^1.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
